# ============================================================
# INNOVATION - Sistema Integral de Gestion de Servicios ISP
# ============================================================
# Copia este archivo como application.properties y completa los valores

spring.application.name=innovation-telecom

# ============================================================
# Server Configuration
# ============================================================
server.port=8210
server.servlet.context-path=/
server.servlet.session.timeout=30m

# ============================================================
# MongoDB Configuration
# ============================================================
spring.data.mongodb.uri=mongodb://USUARIO:PASSWORD@HOST:27017/innovation_telecom?ssl=true&replicaSet=REPLICA_SET&authSource=admin&retryWrites=true&w=majority
spring.data.mongodb.auto-index-creation=true

# ============================================================
# Thymeleaf Configuration
# ============================================================
spring.thymeleaf.cache=false
spring.thymeleaf.encoding=UTF-8
spring.thymeleaf.mode=HTML
spring.thymeleaf.prefix=classpath:/templates/
spring.thymeleaf.suffix=.html
spring.thymeleaf.check-template-location=false

# ============================================================
# DevTools
# ============================================================
spring.devtools.restart.enabled=false

# ============================================================
# Logging Configuration
# ============================================================
logging.level.root=INFO
logging.level.com.innovation=INFO
logging.level.org.springframework.security=INFO
logging.level.org.springframework.data.mongodb.core=INFO
logging.level.org.springframework.web=INFO

# ============================================================
# Jackson Configuration
# ============================================================
spring.jackson.serialization.write-dates-as-timestamps=false
spring.jackson.default-property-inclusion=non_null
spring.jackson.time-zone=UTC

# ============================================================
# Multipart Uploads
# ============================================================
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=12MB

# ============================================================
# JWT Configuration
# ============================================================
app.jwtSecret=TU_SECRET_KEY_CON_MAS_DE_32_CARACTERES
app.jwtExpirationMs=86400000

# ============================================================
# SpringDoc OpenAPI Configuration
# ============================================================
springdoc.api-docs.path=/v3/api-docs
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.enabled=true

# ============================================================
# Actuator Configuration
# ============================================================
management.endpoints.web.exposure.include=health,info
management.endpoint.health.show-details=always
